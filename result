//여기서부터 블루투스 로직 실행
      while(1){
        if(bluetooth.available()){
          char receivedData = bluetooth.read();//블루투스통해 읽은 값 저장용도
          //+추가로 미등록 데이터 입력 시 버퍼를 모두 지운 동작이 있었는데
