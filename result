            operateServo();
            break;
            //탈출하면 while(locked == true) 구문 만나는데 해당사항 아니므로 loop의 처음으로 다시 돌아간다.)
          }
          else{//정답이 아니면
            falseStack++;
            if(falseStack >= 5){
              locked = true;
              //여기서 locked 가 true로 바뀜 
              //지금까지 동작전제가 locked가 false 인데 true니까 종류 후 loop에서 locked == true 조건을 찾아감
              //즉 RFID태그 로직으로 감
              break;            
